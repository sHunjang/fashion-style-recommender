# .gitignore

# ----------------------------------------
# Python
# ----------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----------------------------------------
# 가상환경
# ----------------------------------------
.conda/
env/
venv/
.venv/
conda-meta/

# ----------------------------------------
# 데이터 (용량 큰 파일 제외)
# ----------------------------------------
data/raw/
data/processed/
data/index/

# 단, 폴더 구조는 유지
# (아래 .gitkeep 참고)

# ----------------------------------------
# 모델 가중치
# ----------------------------------------
*.pt
*.pth
*.bin
*.ckpt
*.safetensors

# ----------------------------------------
# FAISS 인덱스
# ----------------------------------------
*.faiss
*.index

# ----------------------------------------
# 환경변수 (API 키 등 보안!)
# ----------------------------------------
.env
.env.local
.env.*.local
secrets.yaml

# ----------------------------------------
# IDE
# ----------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ----------------------------------------
# OS
# ----------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------
# 로그
# ----------------------------------------
*.log
logs/

# ----------------------------------------
# 캐시
# ----------------------------------------
.cache/
*.cache