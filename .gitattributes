# .gitattributes

# ----------------------------------------
# OS 간 줄바꿈 충돌 방지
# Windows: CRLF / Mac, Linux: LF
# → 모두 LF로 통일!
# ----------------------------------------

# 모든 텍스트 파일
* text=auto eol=lf

# 코드 파일
*.py     text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf

# 바이너리 파일 (변환 금지!)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pt     binary
*.pth    binary
*.bin    binary
*.faiss  binary
*.pkl    binary
*.npy    binary
*.npz    binary
*.zip    binary
*.tar    binary
*.gz     binary